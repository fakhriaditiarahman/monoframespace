// ---- SCENE 2: THE PROCESS (TEXT SCRUB) ----
// ⚡ Bolt Optimization: Extracted static text parsing outside component
// 💡 What: Moved `text.split(" ")` outside the render loop
// 🎯 Why: Prevents creating a new string array on every render, reducing garbage collection
//    overhead during high-frequency scroll updates.
const narrativeText = "Di Monoframe, kami percaya bahwa setiap momen, baris kode, dan pixel memiliki cerita. Kami menggabungkan seni visual dengan keunggulan teknis untuk menciptakan pengalaman digital yang tak terlupakan."
const narrativeWords = narrativeText.split(" ")

// ⚡ Bolt Optimization: Extracted loop item into a separate component
// 💡 What: Created `NarrativeWord` component to encapsulate the `useTransform` hook.
// 🎯 Why: Calling `useTransform` inside an array `.map()` loop violates React's Rules of Hooks
//    and causes order instability during re-renders. Extracting it guarantees hook stability.
function NarrativeWord({ word, i, total, scrollYProgress }: { word: string, i: number, total: number, scrollYProgress: any }) {
  const start = i / total
  const end = start + (1 / total)
  const opacity = useTransform(scrollYProgress, [start, end], [0.1, 1])

  return (
    <motion.span style={{ opacity }} className="text-blue-950">
      {word}
    </motion.span>
  )
}

